{
  "name": "@magneta/chain-widgets",
  "version": "0.1.0",
  "description": "Shared React widgets for Magneta cross-chain flows (selector, progress, fee breakdown)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
