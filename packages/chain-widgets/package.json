  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@magneta/chain-service": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3"
  }
}
