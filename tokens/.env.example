# Smart Contract Deployment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED: Private Key for Deployment
# ===========================================
# The private key of the wallet that will deploy contracts
# WARNING: Never commit this file with real keys!
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# ===========================================
# OPTIONAL: Custom RPC URLs
# ===========================================
# Leave empty to use default URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# ===========================================
# OPTIONAL: Basescan API Key for Verification
# ===========================================
# Get your API key at: https://basescan.org/myapikey
BASESCAN_API_KEY=

# ===========================================
# Faucets for Test ETH
# ===========================================
# Base Sepolia Faucet: https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
# Alchemy Faucet: https://www.alchemy.com/faucets/base-sepolia
