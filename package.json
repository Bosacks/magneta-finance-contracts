    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "dotenv": "^16.3.1",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@layerzerolabs/lz-evm-oapp-v2": "^3.0.145",
    "@layerzerolabs/lz-evm-protocol-v2": "^3.0.145",
    "ethers": "^6.9.0"
  }
}