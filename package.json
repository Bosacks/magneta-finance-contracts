{
  "name": "@magneta/contracts",
  "version": "0.1.0",
  "description": "Magneta Finance DEX Smart Contracts",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:base-sepolia": "hardhat run scripts/deploy/deployAll.ts --network baseSepolia",
